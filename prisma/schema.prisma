generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  member
}

enum UserStatus {
  active
  disabled
}

enum SystemStatus {
  active
  disabled
}

enum AuditTargetType {
  AUTH
  USER
  SYSTEM
  EMPLOYEE
  CANDIDATE
  ANNOUNCEMENT
  DOCUMENT
  ATTENDANCE
  LEAVE
}

enum AnnouncementCategory {
  IMPORTANT
  FEATURE
  FIX
  MAINTENANCE
  RELEASE
}

enum AnnouncementStatus {
  PUBLISHED
  DRAFT
}

enum DocumentStatus {
  PUBLISHED
  DRAFT
}

enum EmployeeStatus {
  active
  disabled
}

enum GuideType {
  INTERVIEW
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskFieldType {
  TEXT
  TEXTAREA
  SELECT
  MULTI_SELECT
  DATE
  CHECKBOX
  RADIO
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole   @default(member)
  status       UserStatus @default(active)

  employeeNumber       Int?      @map("employee_number")

  // LINE WORKS アカウントID（例: "masayuki_oono@bizstudio.co.jp"）
  lineworksId          String?   @map("lineworks_id")

  // ManusAPIキー（AES-256-GCM暗号化済み）
  manusApiKeyEncrypted String?   @map("manus_api_key_encrypted")
  manusApiKeySetAt     DateTime? @map("manus_api_key_set_at")

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt      @map("updated_at")

  auditLogs     AuditLog[]     @relation("ActorAuditLogs")
  invitesMade   Invite[]       @relation("InvitesMade")
  appTokens     AppToken[]
  appSessions   AppSession[]
  announcements Announcement[]
  documents     Document[]     @relation("UserDocuments")
  manuals        Manual[]       @relation("UserManuals")
  candidateNotes CandidateNote[] @relation("UserCandidateNotes")
  tasksCreated      Task[]            @relation("TaskCreator")
  taskComments      TaskComment[]     @relation("TaskComments")
  taskAttachments   TaskAttachment[]  @relation("UploadedAttachments")

  // 勤怠管理
  attendanceRecords AttendanceRecord[] @relation("UserAttendance")
  leaveRequests     LeaveRequest[]     @relation("UserLeaveRequests")
  leaveBalances     LeaveBalance[]     @relation("UserLeaveBalances")
  attendanceModRequestsMade AttendanceModRequest[] @relation("ModRequestor")
  attendanceModRequestsReviewed AttendanceModRequest[] @relation("ModReviewer")
  leaveRequestsReviewed LeaveRequest[] @relation("LeaveReviewer")

  @@map("users")
}

model SystemLink {
  id           String       @id @default(cuid())
  name         String
  description  String
  url          String
  status       SystemStatus @default(active)
  sortOrder    Int          @default(0) @map("sort_order")

  // SSO認証連携
  requiresAuth Boolean      @default(false) @map("requires_auth")
  appId        String?      @map("app_id")

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt      @map("updated_at")

  @@map("systems")
}

model Invite {
  id              String    @id @default(cuid())
  email           String
  tokenHash       String    @map("token_hash")
  expiresAt       DateTime  @map("expires_at")
  usedAt          DateTime? @map("used_at")

  createdByUserId String    @map("created_by_user_id")
  createdByUser   User      @relation("InvitesMade", fields: [createdByUserId], references: [id])

  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("invites")
}

model AuditLog {
  id          String          @id @default(cuid())
  actorUserId String          @map("actor_user_id")
  actorUser   User            @relation("ActorAuditLogs", fields: [actorUserId], references: [id])

  action      String
  targetType  AuditTargetType @map("target_type")
  targetId    String?         @map("target_id")
  metadata    Json?

  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([actorUserId, createdAt])
  @@index([targetType, createdAt])
  @@map("audit_logs")
}

model Employee {
  id             String         @id @default(cuid())
  employeeNumber String         @unique @map("employee_number")
  name           String
  status         EmployeeStatus @default(active)

  // 担当求職者
  candidates     Candidate[]
  taskAssignees  TaskAssignee[]

  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt      @map("updated_at")

  @@map("employees")
}

model Candidate {
  id              String   @id @default(cuid())
  candidateNumber String   @unique @map("candidate_number")
  name            String
  nameKana        String?  @map("name_kana")
  gender          String?  // "male" | "female" | "other"
  email           String?

  // 担当キャリアアドバイザー
  employeeId      String?  @map("employee_id")
  employee        Employee? @relation(fields: [employeeId], references: [id])

  guideEntries    GuideEntry[]
  notes           CandidateNote[]
  jimuSessions    JimuSession[]
  tasks           Task[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  @@map("candidates")
}

model CandidateNote {
  id            String    @id @default(cuid())
  candidateId   String    @map("candidate_id")
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  content       String    @db.Text
  authorUserId  String    @map("author_user_id")
  author        User      @relation("UserCandidateNotes", fields: [authorUserId], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("candidate_notes")
}

model GuideEntry {
  id            String    @id @default(cuid())
  candidateId   String    @map("candidate_id")
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  guideType     GuideType @map("guide_type")
  token         String    @unique @default(cuid())
  data          Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([candidateId, guideType])
  @@map("guide_entries")
}

// 外部アプリ遷移用ワンタイムトークン
model AppToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @map("token_hash")
  targetApp String    @map("target_app")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tokenHash])
  @@map("app_tokens")
}

// 外部アプリ用セッション
model AppSession {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id])
  sessionTokenHash String   @map("session_token_hash")
  appId            String   @map("app_id")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([sessionTokenHash])
  @@map("app_sessions")
}

// 資料
model Document {
  id             String          @id @default(cuid())
  title          String
  description    String          @db.Text
  category       String
  url            String
  status         DocumentStatus  @default(DRAFT)
  authorUserId   String          @map("author_user_id")
  author         User            @relation("UserDocuments", fields: [authorUserId], references: [id])
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("documents")
}

// 事務深掘りセッション
model JimuSession {
  id            String    @id @default(cuid())
  token         String    @unique
  candidateId   String?   @map("candidate_id")
  candidate     Candidate? @relation(fields: [candidateId], references: [id])
  candidateName String?   @map("candidate_name")
  state         Json
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")

  @@map("jimu_sessions")
}

// 面接希望日回収URL短縮リンク
model ScheduleLink {
  id              String   @id @default(cuid())
  token           String   @unique
  candidateName   String   @map("candidate_name")
  advisorName     String   @map("advisor_name")
  interviewMethod String   @map("interview_method")
  type            String   @default("interview")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("schedule_links")
}

// お知らせ
model Announcement {
  id           String               @id @default(cuid())
  title        String
  content      String               @db.Text
  category     AnnouncementCategory
  status       AnnouncementStatus   @default(DRAFT)
  publishedAt  DateTime?            @map("published_at")
  authorUserId String               @map("author_user_id")
  author       User                 @relation(fields: [authorUserId], references: [id])
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@map("announcements")
}

enum ManualCategory {
  INTERNAL
  CANDIDATE
  CLIENT
}

enum ManualContentType {
  VIDEO
  PDF
  URL
  MARKDOWN
}

model Manual {
  id              String             @id @default(cuid())
  title           String
  category        ManualCategory
  subCategory     String?            @map("sub_category")
  contentType     ManualContentType  @map("content_type")
  videoUrl        String?            @map("video_url")
  pdfPath         String?            @map("pdf_path")
  pdfData         String?            @map("pdf_data") @db.Text
  driveFileId     String?            @map("drive_file_id")
  driveViewUrl    String?            @map("drive_view_url")
  externalUrl     String?            @map("external_url")
  markdownContent String?            @map("markdown_content") @db.Text
  description     String?            @db.Text
  authorUserId    String             @map("author_user_id")
  author          User               @relation("UserManuals", fields: [authorUserId], references: [id])
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("manuals")
}

// タスクカテゴリグループ
model TaskCategoryGroup {
  id         String         @id @default(cuid())
  name       String         @unique
  sortOrder  Int            @default(0) @map("sort_order")
  categories TaskCategory[]
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@map("task_category_groups")
}

// タスクカテゴリマスター（大分類）
model TaskCategory {
  id          String   @id @default(cuid())
  name        String   // 例: 履歴書作成、職務経歴書作成、推薦状作成
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")

  groupId     String?             @map("group_id")
  group       TaskCategoryGroup?  @relation(fields: [groupId], references: [id])

  fields      TaskTemplateField[]
  tasks       Task[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("task_categories")
}

// カテゴリに紐付くテンプレート項目マスター
model TaskTemplateField {
  id            String        @id @default(cuid())
  categoryId    String        @map("category_id")
  category      TaskCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  label         String        // 表示ラベル（例: 志望動機タイプ）
  fieldType     TaskFieldType @map("field_type")
  isRequired    Boolean       @default(false) @map("is_required")
  placeholder   String?
  description   String?       @db.Text  // ヘルプテキスト・注釈
  sortOrder     Int           @default(0) @map("sort_order")

  options       TaskTemplateOption[]
  fieldValues   TaskFieldValue[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("task_template_fields")
}

// 選択式項目の選択肢マスター
model TaskTemplateOption {
  id        String            @id @default(cuid())
  fieldId   String            @map("field_id")
  field     TaskTemplateField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  label     String
  value     String
  sortOrder Int               @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("task_template_options")
}

// タスク本体
model Task {
  id              String       @id @default(cuid())
  title           String
  description     String?      @db.Text
  categoryId      String?      @map("category_id")
  category        TaskCategory? @relation(fields: [categoryId], references: [id])
  candidateId     String?      @map("candidate_id")
  candidate       Candidate?   @relation(fields: [candidateId], references: [id])
  status          TaskStatus   @default(NOT_STARTED)
  priority        TaskPriority?
  dueDate         DateTime?    @map("due_date")
  createdByUserId String       @map("created_by_user_id")
  createdByUser   User         @relation("TaskCreator", fields: [createdByUserId], references: [id])

  assignees       TaskAssignee[]
  fieldValues     TaskFieldValue[]
  attachments     TaskAttachment[]
  comments        TaskComment[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("tasks")
}

// タスク担当者（複数可）
model TaskAssignee {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([taskId, employeeId])
  @@map("task_assignees")
}

// タスクに入力されたテンプレート値
model TaskFieldValue {
  id        String            @id @default(cuid())
  taskId    String            @map("task_id")
  task      Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fieldId   String            @map("field_id")
  field     TaskTemplateField @relation(fields: [fieldId], references: [id])
  value     String            @db.Text  // JSON文字列（複数選択の場合は配列）

  @@unique([taskId, fieldId])
  @@map("task_field_values")
}

// 添付ファイル
model TaskAttachment {
  id               String   @id @default(cuid())
  taskId           String   @map("task_id")
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName         String   @map("file_name")
  fileSize         Int      @map("file_size")
  mimeType         String   @map("mime_type")
  storagePath      String   @map("storage_path")
  publicUrl        String   @map("public_url")
  uploadedByUserId String   @map("uploaded_by_user_id")
  uploadedByUser   User     @relation("UploadedAttachments", fields: [uploadedByUserId], references: [id])

  createdAt        DateTime @default(now()) @map("created_at")

  @@index([taskId])
  @@map("task_attachments")
}

// コメント
model TaskComment {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("TaskComments", fields: [userId], references: [id])
  content   String   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("task_comments")
}

// 志望動機マスター（大分類）
model MotivationCategoryMajor {
  id        String                    @id @default(cuid())
  name      String                    @unique
  sortOrder Int                       @default(0) @map("sort_order")
  middles   MotivationCategoryMiddle[]
  createdAt DateTime                  @default(now()) @map("created_at")

  @@map("motivation_category_majors")
}

// 志望動機マスター（中分類）
model MotivationCategoryMiddle {
  id        String                   @id @default(cuid())
  name      String
  majorId   String                   @map("major_id")
  major     MotivationCategoryMajor  @relation(fields: [majorId], references: [id], onDelete: Cascade)
  sortOrder Int                      @default(0) @map("sort_order")
  minors    MotivationCategoryMinor[]
  createdAt DateTime                 @default(now()) @map("created_at")

  @@map("motivation_category_middles")
}

// 志望動機マスター（小分類）
model MotivationCategoryMinor {
  id        String                   @id @default(cuid())
  name      String
  middleId  String                   @map("middle_id")
  middle    MotivationCategoryMiddle @relation(fields: [middleId], references: [id], onDelete: Cascade)
  sortOrder Int                      @default(0) @map("sort_order")
  createdAt DateTime                 @default(now()) @map("created_at")

  @@map("motivation_category_minors")
}

// 職種マスター（大分類）
model JobCategoryMajor {
  id        String              @id @default(cuid())
  name      String              @unique
  sortOrder Int                 @default(0) @map("sort_order")
  middles   JobCategoryMiddle[]
  createdAt DateTime            @default(now()) @map("created_at")

  @@map("job_category_majors")
}

// 職種マスター（中分類）
model JobCategoryMiddle {
  id        String             @id @default(cuid())
  name      String
  majorId   String             @map("major_id")
  major     JobCategoryMajor   @relation(fields: [majorId], references: [id], onDelete: Cascade)
  sortOrder Int                @default(0) @map("sort_order")
  minors    JobCategoryMinor[]
  createdAt DateTime           @default(now()) @map("created_at")

  @@map("job_category_middles")
}

// 職種マスター（小分類）
model JobCategoryMinor {
  id        String            @id @default(cuid())
  name      String
  middleId  String            @map("middle_id")
  middle    JobCategoryMiddle @relation(fields: [middleId], references: [id], onDelete: Cascade)
  sortOrder Int               @default(0) @map("sort_order")
  createdAt DateTime          @default(now()) @map("created_at")

  @@map("job_category_minors")
}

// 業種マスター（大分類）
model IndustryCategoryMajor {
  id        String                   @id @default(cuid())
  name      String                   @unique
  sortOrder Int                      @default(0) @map("sort_order")
  middles   IndustryCategoryMiddle[]
  createdAt DateTime                 @default(now()) @map("created_at")

  @@map("industry_category_majors")
}

// 業種マスター（中分類）
model IndustryCategoryMiddle {
  id        String                  @id @default(cuid())
  name      String
  majorId   String                  @map("major_id")
  major     IndustryCategoryMajor   @relation(fields: [majorId], references: [id], onDelete: Cascade)
  sortOrder Int                     @default(0) @map("sort_order")
  minors    IndustryCategoryMinor[]
  createdAt DateTime                @default(now()) @map("created_at")

  @@map("industry_category_middles")
}

// 業種マスター（小分類）
model IndustryCategoryMinor {
  id        String                 @id @default(cuid())
  name      String
  middleId  String                 @map("middle_id")
  middle    IndustryCategoryMiddle @relation(fields: [middleId], references: [id], onDelete: Cascade)
  sortOrder Int                    @default(0) @map("sort_order")
  createdAt DateTime               @default(now()) @map("created_at")

  @@map("industry_category_minors")
}

// ========================================
// 勤怠管理
// ========================================

enum AttendanceStatus {
  NOT_STARTED   // 未出勤
  WORKING       // 勤務中
  ON_BREAK      // 休憩中
  SUSPENDED     // 中断中
  COMPLETED     // 退勤済み（確定）
}

enum PunchType {
  CLOCK_IN       // 出勤
  BREAK_START    // 休憩開始
  BREAK_END      // 休憩終了
  SUSPEND_START  // 中断開始
  SUSPEND_END    // 中断終了
  CLOCK_OUT      // 退勤
}

enum ModRequestStatus {
  PENDING   // 申請中
  APPROVED  // 承認済み
  REJECTED  // 差し戻し
}

enum LeaveType {
  PAID        // 有給休暇
  HALF_PAID   // 有給（半日）
  SICK        // 病欠
  SPECIAL     // 特別休暇
  OTHER       // その他
}

enum LeaveRequestStatus {
  PENDING   // 申請中
  APPROVED  // 承認済み
  REJECTED  // 差し戻し
}

// 勤怠レコード（1日1ユーザー1レコード）
model AttendanceRecord {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  user          User             @relation("UserAttendance", fields: [userId], references: [id])
  date          DateTime         @db.Date  // 勤務日（日付のみ）
  status        AttendanceStatus @default(NOT_STARTED)

  clockIn       DateTime?        @map("clock_in")
  clockOut      DateTime?        @map("clock_out")

  // 計算済み時間（分単位で保存）
  totalWorkMinutes    Int?       @map("total_work_minutes")
  totalBreakMinutes   Int?       @map("total_break_minutes")
  totalSuspendMinutes Int?       @map("total_suspend_minutes")
  overtimeMinutes     Int?       @map("overtime_minutes")
  nightMinutes        Int?       @map("night_minutes")    // 深夜時間（22:00〜翌5:00）

  note          String?          @db.Text  // 備考

  punches       AttendancePunch[]
  modRequests   AttendanceModRequest[]

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@map("attendance_records")
}

// 打刻エントリ（1日に複数）
model AttendancePunch {
  id                 String           @id @default(cuid())
  attendanceRecordId String           @map("attendance_record_id")
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  type               PunchType
  punchedAt          DateTime         @map("punched_at")
  isManual           Boolean          @default(false) @map("is_manual")  // 手動修正か

  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([attendanceRecordId, type])
  @@map("attendance_punches")
}

// 打刻修正申請（退勤後の修正）
model AttendanceModRequest {
  id                 String           @id @default(cuid())
  attendanceRecordId String           @map("attendance_record_id")
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)

  requestedByUserId  String           @map("requested_by_user_id")
  requestedBy        User             @relation("ModRequestor", fields: [requestedByUserId], references: [id])

  status             ModRequestStatus @default(PENDING)
  changes            Json             // { field: "clockIn", before: "...", after: "..." } 等
  reason             String           @db.Text  // 申請理由

  reviewedByUserId   String?          @map("reviewed_by_user_id")
  reviewedBy         User?            @relation("ModReviewer", fields: [reviewedByUserId], references: [id])
  reviewedAt         DateTime?        @map("reviewed_at")
  adminComment       String?          @map("admin_comment") @db.Text  // 差し戻し理由

  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([attendanceRecordId])
  @@index([status])
  @@map("attendance_mod_requests")
}

// 有給・休暇申請
model LeaveRequest {
  id              String             @id @default(cuid())
  userId          String             @map("user_id")
  user            User               @relation("UserLeaveRequests", fields: [userId], references: [id])
  date            DateTime           @db.Date  // 休暇日
  leaveType       LeaveType          @map("leave_type")
  status          LeaveRequestStatus @default(PENDING)
  reason          String?            @db.Text  // 申請理由

  reviewedByUserId String?           @map("reviewed_by_user_id")
  reviewedBy       User?             @relation("LeaveReviewer", fields: [reviewedByUserId], references: [id])
  reviewedAt       DateTime?         @map("reviewed_at")
  adminComment     String?           @map("admin_comment") @db.Text

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@index([status])
  @@map("leave_requests")
}

// 有給残日数管理
model LeaveBalance {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation("UserLeaveBalances", fields: [userId], references: [id])
  fiscalYear  Int      @map("fiscal_year")  // 年度（例: 2026）
  totalDays   Float    @map("total_days")   // 付与日数（半日単位のためFloat）
  usedDays    Float    @default(0) @map("used_days")  // 使用日数

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, fiscalYear])
  @@map("leave_balances")
}
