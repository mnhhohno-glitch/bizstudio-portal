  firstMeetingDate    DateTime? @map("first_meeting_date")
  jobMeetingDate      DateTime? @map("job_meeting_date")
  jobIntroDate        DateTime? @map("job_intro_date")
  documentSubmitDate  DateTime? @map("document_submit_date")
  documentPassDate    DateTime? @map("document_pass_date")
  aptitudeTestExists  Boolean   @default(false) @map("aptitude_test_exists")
  aptitudeTestDeadline DateTime? @map("aptitude_test_deadline")
  interviewPrepDate   DateTime? @map("interview_prep_date")
  interviewPrepTime   String?   @map("interview_prep_time")
  firstInterviewDate  DateTime? @map("first_interview_date")
  firstInterviewTime  String?   @map("first_interview_time")
  secondInterviewDate DateTime? @map("second_interview_date")
  secondInterviewTime String?   @map("second_interview_time")
  finalInterviewDate  DateTime? @map("final_interview_date")
  finalInterviewTime  String?   @map("final_interview_time")
  offerDate           DateTime? @map("offer_date")
  offerDeadline       DateTime? @map("offer_deadline")
  offerMeetingDate    DateTime? @map("offer_meeting_date")
  offerMeetingTime    String?   @map("offer_meeting_time")
  acceptanceDate      DateTime? @map("acceptance_date")
  joinDate            DateTime? @map("join_date")

  memo                String?   @db.Text
  jobDbUrl            String?   @map("job_db_url")
  isActive            Boolean   @default(true) @map("is_active")
  careerAdvisorId     String?   @map("career_advisor_id")
  archivedAt          DateTime? @map("archived_at")

  // === 財務 ===
  theoreticalIncome   Int?      @map("theoretical_income")
  referralFee         Int?      @map("referral_fee")
  revenue             Int?      @map("revenue")
  grossProfit         Int?      @map("gross_profit")

  // === 応募経路 ===
  route               String?

  // === エントリー媒体切替（紹介時とエントリー時で異なる媒体に対応） ===
  entryRoute          String?   @map("entry_route")
  entryJobId          String?   @map("entry_job_id")

  // === FileMaker参照用 ===
  fmEntryNo           String?   @map("fm_entry_no")

  @@index([candidateId])
  @@index([externalJobId])
  @@index([entryFlag])
  @@index([isActive])
  @@index([archivedAt])
  @@map("job_entries")
}

